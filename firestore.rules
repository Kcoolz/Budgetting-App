rules_version = '2';

// Paste this whole file into Firebase Console -> Firestore Database -> Rules,
// replace the two placeholder emails with your real Google account emails
// (lowercase), then click Publish.
//
// This is the ONLY thing that protects your data. Only the Google accounts
// listed here can read or write anything — everyone else (including other
// signed-in Google users) is rejected by Google's servers.
service cloud.firestore {
  match /databases/{database}/documents {
    function isHouseholdMember() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email_verified == true
        && request.auth.token.email.lower() in [
          'your-email@gmail.com',
          'partner-email@gmail.com'
        ];
    }

    match /households/main/{document=**} {
      allow read, write: if isHouseholdMember();
    }

    // Everything else is denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
